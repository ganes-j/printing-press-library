    {
      "name": "database_search",
      "description": "Search the Discogs database. Public data; a token raises the rate limit from 25 to 60/min. Required: q. Optional: type, title, artist (plus 10 more).",
      "method": "GET",
      "path": "/database/search",
      "params": [
        {
          "name": "q",
          "type": "string",
          "location": "path",
          "description": "Free-text query (title, artist, catalog no, barcode)."
        },
        {
          "name": "type",
          "type": "string",
          "location": "query",
          "description": "Restrict to one entity type."
        },
        {
          "name": "title",
          "type": "string",
          "location": "query",
          "description": "Search a combined 'Artist - Title' field."
