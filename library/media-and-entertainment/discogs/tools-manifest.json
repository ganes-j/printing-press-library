      "path": "/users/{username}/collection/folders/{folder_id}",
      "params": [
        {
          "name": "username",
          "type": "string",
          "location": "path",
          "required": true
        },
        {
          "name": "folder_id",
          "type": "int",
          "location": "path",
          "required": true
        }
      ]
    },
    {
      "name": "collection_fields",
