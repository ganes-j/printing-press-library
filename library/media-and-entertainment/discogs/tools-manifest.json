{
  "api_name": "discogs",
  "base_url": "https://api.discogs.com",
  "description": "Every Discogs feature — plus a local price-history mirror the API doesn't keep, so you can watch your wantlist like a limit-order book, spot underpriced records, and track your collection's value over time.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "mcp": {
    "endpoint_tools": "hidden",
    "orchestration": "code"
  },
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "format": "Discogs token={DISCOGS_TOKEN}",
    "in": "header",
    "env_vars": [
      "DISCOGS_TOKEN"
    ],
    "env_var_specs": [
      {
        "name": "DISCOGS_TOKEN",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [
    {
      "name": "User-Agent",
      "value": "discogs-pp-cli/1.0 +https://github.com/mvanhorn/discogs-pp-cli"
    }
  ],
  "tools": [
    {
      "name": "collection_add",
      "description": "Add a release to a collection folder. Required: username, folder_id, release_id.",
      "method": "POST",
      "path": "/users/{username}/collection/folders/{folder_id}/releases/{release_id}",
      "params": [
        {
          "name": "username",
          "type": "string",
          "location": "path",
          "description": "Discogs username.",
          "required": true
        },
        {
          "name": "folder_id",
          "type": "int",
          "location": "path",
          "description": "Folder ID to add into.",
          "required": true
        },
        {
          "name": "release_id",
          "type": "int",
          "location": "path",
          "description": "Discogs release ID to add.",
          "required": true
        }
      ]
    },
    {
      "name": "collection_create_folder",
      "description": "Create a new collection folder. Required: username, name.",
      "method": "POST",
      "path": "/users/{username}/collection/folders",
      "params": [
        {
          "name": "username",
          "type": "string",
          "location": "path",
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "New folder name.",
          "required": true
        }
      ]
    },
    {
      "name": "collection_delete_folder",
      "description": "Delete a collection folder (must be empty). Required: username, folder_id. Destructive.",
