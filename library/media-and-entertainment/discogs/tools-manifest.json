        },
        {
          "name": "style",
          "type": "string",
          "location": "query",
          "description": "Style (e.g. House, Grunge, Hard Bop)."
        },
        {
          "name": "country",
          "type": "string",
          "location": "query",
          "description": "Country of release."
        },
        {
          "name": "year",
          "type": "string",
          "location": "query",
          "description": "Year of release."
        },
        {
          "name": "format",
          "type": "string",
          "location": "query",
          "description": "Format (Vinyl, CD, Cassette, Box Set)."
        },
        {
          "name": "catno",
          "type": "string",
          "location": "query",
          "description": "Catalog number."
        },
        {
          "name": "barcode",
          "type": "string",
          "location": "query",
          "description": "Barcode."
        },
        {
          "name": "per-page",
          "wire_name": "per_page",
          "type": "int",
          "location": "query",
          "description": "Results per page (max 100)."
        },
        {
          "name": "page",
          "type": "int",
          "location": "query",
          "description": "Page number."
        }
      ]
