{
  "api_name": "namecheap",
  "base_url": "https://api.namecheap.com",
  "description": "Curated OpenAPI description for Namecheap's XML API. The real API uses a single\nendpoint (`/xml.response`) with a `Command` query parameter plus Namecheap's\nquery-string authentication parameters (`ApiUser`, `ApiKey`, `UserName`, `ClientIp`).\nGeneration uses command-shaped pseudo paths that are normalized back to `/xml.response`\nby the Namecheap printed CLI patch layer.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "api_key",
    "header": "ApiKey",
    "in": "query",
    "env_vars": [
      "NAMECHEAP_API_KEY_QUERY"
    ],
    "env_var_specs": [
      {
        "name": "NAMECHEAP_API_KEY_QUERY",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "xml-response_domains-check",
      "description": "Check domain availability for one or more domains. Optional: DomainList.",
      "method": "GET",
      "path": "/xml.response/domains/check",
      "params": [
        {
          "name": "DomainList",
          "type": "string",
          "location": "query",
          "description": "Comma-separated list of domains (maximum 50 for domains.check)."
        }
      ]
    },
    {
      "name": "xml-response_domains-create",
      "description": "Runs `namecheap.domains.create`. This is a mutating paid operation; use dry-run unless intentionally registering. Optional: DomainName, Years, PromotionCode (plus 3 more).",
      "method": "GET",
      "path": "/xml.response/domains/create",
      "params": [
        {
          "name": "DomainName",
          "type": "string",
          "location": "query",
          "description": "Fully qualified domain name."
        },
        {
          "name": "Years",
          "type": "int",
          "location": "query",
          "description": "Years"
        },
        {
          "name": "PromotionCode",
          "type": "string",
          "location": "query",
          "description": "Promotion code"
        },
        {
          "name": "AddFreeWhoisguard",
          "type": "string",
          "location": "query",
          "description": "Add free whoisguard"
        },
        {
          "name": "WGEnabled",
          "type": "string",
          "location": "query",
          "description": "Wgenabled"
        },
        {
          "name": "Nameservers",
          "type": "string",
          "location": "query",
          "description": "Comma-separated nameservers"
        }
      ]
    },
    {
      "name": "xml-response_domains-dns-get-email-forwarding",
      "description": "Runs `namecheap.domains.dns.getEmailForwarding`. Optional: DomainName.",
      "method": "GET",
      "path": "/xml.response/dns/get-email-forwarding",
      "params": [
        {
          "name": "DomainName",
          "type": "string",
          "location": "query",
          "description": "Fully qualified domain name."
        }
      ]
    },
    {
      "name": "xml-response_domains-dns-get-hosts",
      "description": "Runs `namecheap.domains.dns.getHosts`. Optional: SLD, TLD.",
      "method": "GET",
      "path": "/xml.response/dns/get-hosts",
      "params": [
        {
          "name": "SLD",
          "type": "string",
          "location": "query",
          "description": "Second-level domain, without the TLD."
        },
        {
          "name": "TLD",
          "type": "string",
          "location": "query",
          "description": "Top-level domain without the leading dot."
        }
      ]
    },
    {
