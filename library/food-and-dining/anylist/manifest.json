{
  "manifest_version": "0.3",
  "name": "anylist-pp-mcp",
  "display_name": "AnyList",
  "version": "4.6.1",
  "description": "Anylist API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/anylist-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/anylist-pp-mcp",
      "args": [],
      "env": {
        "ANYLIST_ACCESS_TOKEN": "${user_config.anylist_access_token}"
      }
    }
  },
  "user_config": {
    "anylist_access_token": {
      "type": "string",
      "title": "ANYLIST_ACCESS_TOKEN",
      "description": "Sets ANYLIST_ACCESS_TOKEN for the AnyList MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
