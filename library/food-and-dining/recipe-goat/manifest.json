{
  "manifest_version": "0.3",
  "name": "recipe-goat-pp-mcp",
  "display_name": "Recipe GOAT",
  "version": "3.6.0",
  "description": "Recipe GOAT API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/recipe-goat-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/recipe-goat-pp-mcp",
      "args": [],
      "env": {
        "USDA_FDC_API_KEY": "${user_config.usda_fdc_api_key}"
      }
    }
  },
  "user_config": {
    "usda_fdc_api_key": {
      "type": "string",
      "title": "USDA_FDC_API_KEY",
      "description": "Optional. Sets USDA_FDC_API_KEY for the Recipe GOAT MCP server. Get a credential from https://fdc.nal.usda.gov/api-key-signup.",
      "sensitive": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
