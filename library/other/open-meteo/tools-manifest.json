        },
        {
          "name": "temperature_unit",
          "type": "string",
          "location": "query",
          "description": "Temperature unit."
        },
        {
          "name": "wind_speed_unit",
          "type": "string",
          "location": "query",
          "description": "Wind speed unit."
        },
        {
          "name": "precipitation_unit",
          "type": "string",
          "location": "query",
          "description": "Precipitation unit."
        },
        {
          "name": "timeformat",
          "type": "string",
          "location": "query",
          "description": "Time output format."
        },
        {
          "name": "timezone",
          "type": "string",
          "location": "query",
          "description": "Named timezone, auto, or UTC."
        },
        {
          "name": "models",
          "type": "string",
          "location": "query",
          "description": "Comma-separated archive models (era5_seamless, era5, era5_land, ecmwf_ifs, cerra)."
