        },
        {
          "name": "precipitation_unit",
          "type": "string",
          "location": "query",
          "description": "Precipitation unit."
        },
        {
          "name": "timeformat",
          "type": "string",
          "location": "query",
          "description": "Time output format."
        },
        {
          "name": "models",
          "type": "string",
          "location": "query",
          "description": "Comma-separated CMIP6 models (EC_Earth3P_HR,CMCC_CM2_VHR4,MRI_AGCM3_2_S,MPI_ESM1_2_XR,FGOALS_f3_H,NICAM16_8S,HiRAM_SIT_HR)."
        },
