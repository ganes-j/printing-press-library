{
  "api_name": "open-meteo",
  "base_url": "https://api.open-meteo.com",
  "description": "Free, open-source weather, climate, and air-quality data — covers Open-Meteo's full no-API-key surface (forecast, archive, marine, air-quality, flood, climate, ensemble, seasonal, geocoding, elevation).",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "air-quality_get",
      "description": "Air quality forecast and historical: pollutants, AQI, pollen, UV. Required: latitude, longitude. Optional: hourly, current, timeformat (default: iso8601) (plus 8 more).",
      "method": "GET",
      "path": "/v1/air-quality",
      "no_auth": true,
      "params": [
        {
          "name": "latitude",
          "type": "string",
          "location": "query",
          "description": "WGS84 latitude. Comma-separated for batch.",
          "required": true
        },
        {
          "name": "longitude",
          "type": "string",
          "location": "query",
          "description": "WGS84 longitude. Comma-separated for batch.",
          "required": true
        },
        {
          "name": "hourly",
          "type": "string",
          "location": "query",
          "description": "Hourly variables (pm10,pm2_5,carbon_monoxide,nitrogen_dioxide,ozone,sulphur_dioxide,uv_index,uv_index_clear_sky,european_aqi,us_aqi,alder_pollen,birch_pollen,grass_pollen,mugwort_pollen,olive_pollen,ragweed_pollen,...)."
        },
        {
          "name": "current",
          "type": "string",
          "location": "query",
          "description": "Current air-quality variables."
        },
        {
          "name": "timeformat",
          "type": "string",
          "location": "query",
          "description": "Time output format."
        },
        {
          "name": "timezone",
          "type": "string",
          "location": "query",
          "description": "Named timezone, auto, or UTC."
        },
        {
          "name": "past_days",
          "type": "int",
          "location": "query",
          "description": "Include past days."
        },
        {
          "name": "forecast_days",
          "type": "int",
          "location": "query",
          "description": "Forecast days (1-7)."
        },
        {
          "name": "forecast_hours",
          "type": "int",
          "location": "query",
          "description": "Forecast hours."
        },
        {
          "name": "past_hours",
          "type": "int",
          "location": "query",
          "description": "Past hours."
        },
        {
          "name": "start_date",
          "type": "string",
          "location": "query",
          "description": "Start date."
        },
        {
          "name": "end_date",
          "type": "string",
          "location": "query",
          "description": "End date."
        },
        {
          "name": "domains",
          "type": "string",
          "location": "query",
          "description": "Air-quality model domain."
        }
      ]
    },
