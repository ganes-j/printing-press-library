{
  "manifest_version": "0.3",
  "name": "open-meteo-pp-mcp",
  "display_name": "Open-Meteo",
  "version": "3.6.1",
  "description": "Forecasts, historicals, marine, air quality, flood, climate, ensemble, and seasonal data from Open-Meteo's free tier.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/open-meteo-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/open-meteo-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
