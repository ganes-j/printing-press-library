{
  "manifest_version": "0.3",
  "name": "coingecko-pp-mcp",
  "display_name": "Coingecko",
  "version": "2.3.7",
  "description": "Coingecko API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
